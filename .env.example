# Optional — only needed if NOT using subscription auth via ~/.claude
# YOLO_ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot (get token from @BotFather, user ID from @userinfobot)
# YOLO_TELEGRAM_BOT_TOKEN=7123456789:AAF...
# YOLO_TELEGRAM_ALLOWED_USERS=[123456789]

# Auth — leave empty to disable (no login required)
# YOLO_AUTH_TOKEN=mein-geheimer-token

# Max concurrent container runs (default: 3)
# YOLO_MAX_CONCURRENT_RUNS=3
